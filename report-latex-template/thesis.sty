\newenvironment{acknowledgments}{
  \clearpage
  \chapter*{Lời cảm ơn}
  \addcontentsline{toc}{chapter}{Lời cảm ơn}
  % \chapter* không tự gọi \markboth (khác với \chapter thường) nên set thủ công.
  \markboth{LỜI CẢM ƠN}{}
  \quotation
}{\par}

