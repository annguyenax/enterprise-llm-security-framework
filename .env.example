# Copy this file to .env and fill in real values locally.
# NEVER commit a real .env file. NEVER put real secrets in this .env.example file.
# All values below are placeholders only.

# --- LLM Provider (API-based, per PROJECT_PLAN.md technical direction) ---
LLM_PROVIDER=changeme
LLM_API_KEY=changeme
LLM_MODEL=changeme

# --- Gateway ---
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8000
LOG_LEVEL=INFO

# --- Vector store (decision deferred, see docs/decisions/) ---
VECTOR_STORE_PATH=./data/vector_store

# --- Logging ---
LOG_FILE_PATH=./logs/gateway.jsonl

# Reminder: any call to a paid API requires explicit user approval
# per AGENT_RULES.md rule 4.
